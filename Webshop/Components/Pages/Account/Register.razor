@page "/register"

@using System.Security.Claims
@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Authentication.Cookies
@using Webshop.Data
@inject DataContext dataContext;
@inject NavigationManager navigationManager;

<div class="row">
    <div class="col-lg-4 offset-lg-4 pt-4 pb-4 border">
        <EditForm Model="@Model" OnValidSubmit=@ValidFormSubmitted OnInvalidSubmit=@InvalidFormSubmitted FormName="RegistrationForm">
            <DataAnnotationsValidator />
            <div class="mb-3 text-center flex-column">
                <img src="/images/login.png" style="max-height:5rem;" />
                <h3>REGISTREREN</h3>
            </div>
            <div class="mb-3">
                <label>Voornaam</label>
                <InputText @bind-Value="Model.FirstName" class="form-control" placeholder="Vul hier uw voornaam in" />
                <ValidationMessage For="() => Model.FirstName" />
            </div>
            <div class="mb-3">
                <label>Tussenvoegsel</label>
                <InputText @bind-Value="Model.Prefix" class="form-control" placeholder="Tussenvoegsel" />
                <ValidationMessage For="() => Model.Prefix" />
            </div>
            <div class="mb-3">
                <label>Achternaam</label>
                <InputText @bind-Value="Model.LastName" class="form-control" placeholder="Vul hier uw achternaam in" />
                <ValidationMessage For="() => Model.LastName" />
            </div>
            <div class="mb-3">
                <label>Straat</label>
                <InputText @bind-Value="Model.Street" class="form-control" placeholder="Vul hier uw straatnaam in" />
                <ValidationMessage For="() => Model.Street" />
            </div>
            <div class="mb-3">
                <label>Huisnummer</label>
                <InputText @bind-Value="Model.HouseNumber" class="form-control" placeholder="Vul hier uw huisnummer in" />
                <ValidationMessage For="() => Model.HouseNumber" />
            </div>
            <div class="mb-3">
                <label>Postcode</label>
                <InputText @bind-Value="Model.Zipcode" class="form-control" placeholder="Vul hier uw postcode in" />
                <ValidationMessage For="() => Model.Zipcode" />
            </div>
            <div class="mb-3">
                <label>Stad</label>
                <InputText @bind-Value="Model.City" class="form-control" placeholder="Vul hier uw postcode in" />
                <ValidationMessage For="() => Model.City" />
            </div>
            <div class="mb-3">
                <label>Emailadres</label>
                <InputText @bind-Value="Model.Email" class="form-control" placeholder="Vul hier uw emailadres in" />
                <ValidationMessage For="() => Model.Email" />
            </div>
            <div class="mb-3">
                <label>Wachtwoord</label>
                <InputText @bind-Value="Model.Password" class="form-control" placeholder="Vul hier uw wachtwoord in" />
                <ValidationMessage For="() => Model.Password" />
            </div>

            <div class="mb-3">
                <label>Herhaal wachtwoord</label>
                <InputText @bind-Value="Model.PasswordCheck" class="form-control" placeholder="Vul hier nogmaals uw wachtwoord in" />
                <ValidationMessage For="() => Model.Password" />
            </div>
            <div class="mb-3 text-center">
                <span class="text-danger">@errorMessage</span>
            </div>
            <div class="mb-3 d-grid gap-2">
                <button type="submit" class="btn btn-primary">Registreren</button>
            </div>
        </EditForm>
    </div>
</div>


@code {
    [SupplyParameterFromForm]
    public RegisterViewModel Model { get; set; } = new();

    private string? errorMessage;

    void ValidFormSubmitted(EditContext editContext)
    {
        // bind data 
    }

    void InvalidFormSubmitted(EditContext editContext)
    {
        // Geef foutmelding
    }


}